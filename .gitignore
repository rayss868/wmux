# E0 conformance harness M3 — esctest2 vendor (GPL-2.0, NEVER commit).
# Cloned at run time by fetch-esctest.sh (pinned commit); no GPL code in the
# repo, CI cache, or any build artifact (spec §5-3 GPL isolation policy).
core/harness/esctest/vendor/
