{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist/cli",
    "rootDir": "src",
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "src/cli/**/*",
    "src/shared/rpc.ts",
    "src/shared/constants.ts",
    "src/shared/types.ts"
  ],
  "exclude": [
    "src/cli/__tests__/**"
  ]
}
